{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ptscribe",
  "main": "worker/index.ts",
  "compatibility_date": "2026-04-26",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
  },
  "ai": {
    "binding": "AI",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ptscribe-auth",
      "database_id": "0bf276aa-5f23-4052-823e-ee79f39e3c69",
    },
  ],
  "kv_namespaces": [
    {
      "binding": "RATE_LIMIT",
      "id": "f877f83936664e6ea409c492aa37c20d",
    },
  ],
  "r2_buckets": [
    {
      "binding": "MODELS",
      "bucket_name": "ptnotes-models",
    },
  ],
  // BYOK provider-key encryption master (ADR-0009). worker/keyCrypto.ts reads it
  // via env.KEY_ENC_MASTER.get() and FAILS CLOSED if this binding is absent —
  // every key save/use returns 5xx until it is present. The secret value lives in
  // the account Secrets Store (store "ptscribe"); only the binding lives here.
  "secrets_store_secrets": [
    {
      "binding": "KEY_ENC_MASTER",
      "store_id": "1a8981cc326a4ce68ad6aa5cdf7c995b",
      "secret_name": "KEY_ENC_MASTER",
    },
  ],
  // Per-IP rate limiting (GA Workers Rate Limiting binding). In-network and
  // per-Cloudflare-location — no KV reads/writes. The KV RATE_LIMIT namespace
  // above is now used only for the post-gate global daily Anthropic-spend
  // counter. period must be 10 or 60. namespace_id is an arbitrary unique
  // per-account integer (as a string).
  "ratelimits": [
    {
      "name": "API_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": { "limit": 10, "period": 60 },
    },
    {
      "name": "PREGATE_RATE_LIMITER",
      "namespace_id": "1002",
      "simple": { "limit": 20, "period": 60 },
    },
  ],
  "observability": {
    "enabled": true,
  },
}
