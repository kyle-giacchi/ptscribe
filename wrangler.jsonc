{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ptscribe",
  "main": "worker/index.ts",
  "compatibility_date": "2026-04-26",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "ai": {
    "binding": "AI"
  },
  "observability": {
    "enabled": true
  }
}
