echo "Running lint-staged..."
npx lint-staged
if [ $? -ne 0 ]; then
  echo ""
  echo "Lint errors on staged files — commit blocked. Fix errors before committing."
  exit 1
fi

echo "Running typecheck..."
npm run typecheck 2>&1
if [ $? -ne 0 ]; then
  echo ""
  echo "TypeScript errors found — commit blocked. Fix errors before committing."
  exit 1
fi

echo "Running tests..."
# Use a temp file instead of $() to avoid POSIX sh exiting on non-zero vitest
# exit code (worker infrastructure crashes exit non-zero even when tests pass).
npm run test -- --run 2>&1 | tee .git/test_output.tmp || true
if grep -qE "^ +Tests +[0-9]+ failed" .git/test_output.tmp; then
  rm -f .git/test_output.tmp
  echo ""
  echo "Tests failed — commit blocked. Fix failing tests before committing."
  exit 1
fi
if grep -qE "^ +Test Files +[0-9]+ failed" .git/test_output.tmp; then
  rm -f .git/test_output.tmp
  echo ""
  echo "Test files failed — commit blocked. Fix failing tests before committing."
  exit 1
fi
rm -f .git/test_output.tmp

exit 0
